# ── Ollama (local LLM) ────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Support contact (shown when bot cannot help) ─────────────
# Official NDSAP PMU contact from the data.gov.in corpus.
SUPPORT_EMAIL=ndsap@gov.in
SUPPORT_PHONE=011-24363692
SUPPORT_URL=https://data.gov.in/contact

# ── Dummy API base URLs (replace with real ones later) ───────
SEARCH_API_URL=https://api.example.gov/search
CDO_DETAILS_API_URL=https://api.example.gov/cdo/details
DATASET_CDO_API_URL=https://api.example.gov/dataset/cdo
FEEDBACK_API_URL=https://api.example.gov/feedback
CONTACT_CDO_API_URL=https://api.example.gov/contact-cdo

# ── Predefined Q&A (JSON strings, add as many as needed) ─────
# Format: PREDEFINED_QA_N={"q": "question text", "a": "answer text"}
# Sourced from data.gov.in: About page, FAQ, Help, NDSAP Implementation
# Guidelines, Terms of Use, Miscellaneous Policies, Accessibility Statement.
PREDEFINED_QA_1={"q": "What is data.gov.in?", "a": "data.gov.in is the Open Government Data (OGD) Platform India, designed, developed and hosted by the National Informatics Centre (NIC) under the Ministry of Electronics & Information Technology, providing proactive access to Government of India shareable datasets, apps and tools in human and machine readable forms under NDSAP."}
PREDEFINED_QA_2={"q": "How do I register on the portal?", "a": "Click the Login button on the top right of any data.gov.in page and sign up with an email and password. Once registered, you can post blogs, contribute community apps, create forum topics, submit requests for API, suggest/endorse datasets, comment on blogs and forums, and generate API keys from your Visitors Dashboard."}
PREDEFINED_QA_3={"q": "How do I download a dataset?", "a": "Browse or search the catalogs on data.gov.in, open the desired dataset and use the Single Click Link provided on the resource. Datasets are published in open machine-readable formats such as CSV, XLS, ODS, XML, RDF, KML, GML and RSS/ATOM. Access may be Open, Registered or Restricted as stated on the resource."}
PREDEFINED_QA_4={"q": "Which formats are datasets available in?", "a": "Under NDSAP, data is published in open machine-readable formats: CSV, XLS, ODS, XML, RDF, KML, GML, and RSS/ATOM for fast-changing data. Hand-written notes, scanned PDFs and non-Unicode formats are avoided."}
PREDEFINED_QA_5={"q": "How do I get an API key?", "a": "Login to data.gov.in with your registered account, go to your Visitors Dashboard and use the API Key generation facility. The generated key is used to access the API URLs of the datasets you wish to consume."}
PREDEFINED_QA_6={"q": "What is NDSAP?", "a": "NDSAP is the National Data Sharing and Accessibility Policy of the Government of India. It applies to all data and information created, generated, collected and archived using public funds by Ministries, Departments, Organisations, Agencies and Autonomous Bodies, and enables proactive open access to shareable, non-sensitive data through the OGD Platform India."}
PREDEFINED_QA_7={"q": "Who is a Chief Data Officer?", "a": "A Chief Data Officer (CDO), formerly called Data Controller, is a senior officer at the level of Joint Secretary or above nominated by a Government entity to head its NDSAP Cell, lead its open data initiative, nominate Data Contributors, prepare the Negative List, identify High-Value Datasets, and approve datasets for publication on data.gov.in."}
PREDEFINED_QA_8={"q": "Who can contribute datasets to data.gov.in?", "a": "Only nominated Chief Data Officers and the Data Contributors they create can contribute datasets through the web-based Data Management System (DMS) at data.gov.in. Datasets pass through a predefined workflow and are published by the NDSAP PMU at NIC headquarters after CDO approval."}
PREDEFINED_QA_9={"q": "How do I give feedback or suggest a new dataset?", "a": "Registered users can rate datasets on Quality, Accessibility and Usability, send queries and feedback via the Feedback or Contact Us page, and submit suggestions for new datasets through the Suggestions module. Suggestions and feedback are routed to the relevant department's Chief Data Officer for action."}
PREDEFINED_QA_10={"q": "What accessibility features does data.gov.in provide?", "a": "data.gov.in is designed to meet WCAG 2.0 priority 2 (level AA). Features include Skip to Main Content, Skip to Navigation, adjustable text size (A+/A/A-), High Contrast and Standard Contrast colour schemes, descriptive link text, alternate text on images, table headers, keyboard support via Tab/Shift+Tab, and compatibility with screen readers such as JAWS, NVDA, SAFA, Supernova and Window-Eyes."}
PREDEFINED_QA_11={"q": "What are the terms of use of the portal?", "a": "Content on data.gov.in is provided as-is and should not be construed as a statement of law. Material may be reproduced accurately with prominent acknowledgement of source, but not used in a derogatory or misleading context. Third-party copyright material requires separate authorisation. These terms are governed by Indian law and disputes fall under the exclusive jurisdiction of Indian courts."}
PREDEFINED_QA_12={"q": "How do I contact the NDSAP PMU?", "a": "NDSAP PMU, National Informatics Centre, DeitY, Room No. 375, 3rd Floor, A Block, CGO Complex, Lodi Road, New Delhi - 110003. Phone: 011-24363692, 011-24305395, 011-24305370. Email: ndsap@gov.in."}

# ── ChromaDB persistence path ─────────────────────────────────
CHROMA_DB_PATH=./chroma_db

# ── PDF folder ────────────────────────────────────────────────
PDF_FOLDER=./pdfs

# ── Similarity thresholds ─────────────────────────────────────
RAG_RELEVANCE_THRESHOLD=0.45
QA_MATCH_THRESHOLD=0.75
RAG_TOP_K=5

# ── Moderation & scope gates ──────────────────────────────────
# When enabled, every user message is classified by Ollama into one of
# SAFE / POLITICAL / INJECTION / OOS before RAG runs. INJECTION catches
# prompt-override attempts ("ignore previous instructions", "pretend
# you are uncensored", etc.) without enumerating bad words. Adds
# ~200-400ms latency per turn on a 3B model.
LLM_MODERATION_ENABLED=true

# Optional safety floor. When enabled, every grounded RAG answer is
# checked by a second Ollama call: "is this response fully supported
# by the retrieved context?". If not, the answer is replaced with the
# out-of-scope refusal. Doubles per-turn LLM call count when on.
# Default off; turn on for high-stakes deployments.
ENABLE_OUTPUT_VERIFICATION=false

# Minimum cosine similarity between the user message and the nearest
# in-scope example utterance (see SCOPE_TOPICS). A query passes the
# prototype scope gate if its embedding looks like one of those
# example utterances. The corpus itself is the second scope signal:
# any query that retrieves a chunk above RAG_RELEVANCE_THRESHOLD also
# counts as in-scope, regardless of this gate.
SCOPE_THRESHOLD=0.45

# Example utterances the assistant is willing to handle (greetings,
# portal usage, CDO contact, dataset search, feedback). JSON array of
# short concrete phrases — NOT abstract topic descriptions. Leave
# unset to use the defaults baked into app/config.py.
# SCOPE_TOPICS=["hi", "what can you do", "how do I download a dataset", "who is the chief data officer", "I want to give feedback"]
