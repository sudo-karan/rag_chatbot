# ── Ollama (local LLM) ────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Support contact (shown when bot cannot help) ─────────────
SUPPORT_EMAIL=support@dataportalgov.in
SUPPORT_PHONE=1800-XXX-XXXX
SUPPORT_URL=https://data.gov.in/contact

# ── Dummy API base URLs (replace with real ones later) ───────
SEARCH_API_URL=https://api.example.gov/search
CDO_DETAILS_API_URL=https://api.example.gov/cdo/details
DATASET_CDO_API_URL=https://api.example.gov/dataset/cdo
FEEDBACK_API_URL=https://api.example.gov/feedback
CONTACT_CDO_API_URL=https://api.example.gov/contact-cdo

# ── Predefined Q&A (JSON strings, add as many as needed) ─────
# Format: PREDEFINED_QA_N={"q": "question text", "a": "answer text"}
PREDEFINED_QA_1={"q": "What is this portal?", "a": "This is the Government Open Data Portal, a platform for accessing and sharing official government datasets."}
PREDEFINED_QA_2={"q": "How do I download a dataset?", "a": "To download a dataset, navigate to the dataset page and click the Download button. Datasets are available in CSV, JSON, and XML formats."}
PREDEFINED_QA_3={"q": "Who can upload datasets?", "a": "Only verified Chief Data Officers (CDOs) from registered government ministries and departments can upload datasets."}
PREDEFINED_QA_4={"q": "Is this portal free to use?", "a": "Yes, the portal is completely free for all citizens and organisations."}
PREDEFINED_QA_5={"q": "How do I report an issue with a dataset?", "a": "You can report an issue by using the feedback form on the dataset page or by contacting the Chief Data Officer responsible for that dataset."}

# ── ChromaDB persistence path ─────────────────────────────────
CHROMA_DB_PATH=./chroma_db

# ── PDF folder ────────────────────────────────────────────────
PDF_FOLDER=./pdfs

# ── Similarity thresholds ─────────────────────────────────────
RAG_RELEVANCE_THRESHOLD=0.45
QA_MATCH_THRESHOLD=0.75
RAG_TOP_K=5

# ── Moderation & scope gates ──────────────────────────────────
# When enabled, every user message is classified by Ollama for sensitive
# content (politics, geopolitics, religion, legal advice, etc.) before
# RAG runs. Adds ~200-400ms latency per turn on a 3B model.
LLM_MODERATION_ENABLED=true

# Minimum cosine similarity between the user message and the nearest
# in-scope topic descriptor (see SCOPE_TOPICS). Below this the bot
# refuses with the out-of-scope response.
SCOPE_THRESHOLD=0.25

# In-scope topic descriptors. JSON array of short natural-language
# descriptions of the domains this assistant covers. Leave unset to
# use the defaults baked into app/config.py.
# SCOPE_TOPICS=["Government Open Data Portal usage", "Chief Data Officers", "Datasets and downloads", "Topics in the portal documentation"]
